# Azure App Configuration
APP_CONFIG_ENDPOINT=<from Azure deployment outputs>

# Key Vault
KEY_VAULT_NAME=<from Azure deployment outputs>

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=<from Azure deployment outputs>

# Azure Resources
RESOURCE_GROUP=pools-dev-rg
LOCATION=centralus
FUNCTION_APP_URL=<from Azure deployment outputs>
STATIC_WEB_APP_URL=<from Azure deployment outputs>
